# ============================================================
# AILAND Frontend Environment Variables
# ============================================================

VITE_API_URL=http://localhost:5000/api
VITE_APP_NAME=AILAND
VITE_APP_SUBTITLE=Tamil Nadu Agriculture & Land Survey

# TNGIS WMS tile layer (survey boundary overlay on satellite map)
# Leave blank to disable WMS overlay — polygons will still be drawn from API data
VITE_TNGIS_WMS_URL=https://tngis.tn.gov.in/geoserver/wms
VITE_TNGIS_WMS_LAYER=tngis:survey_cadastral
